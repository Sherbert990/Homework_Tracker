# ─── Required ────────────────────────────────────────────────────────────────

# MySQL connection string. On Railway, reference the MySQL service instead of
# hardcoding, e.g. DATABASE_URL=${{MySQL.MYSQL_URL}}
DATABASE_URL=mysql://user:pass@host:port/dbname

# Public base URL of the deployed app (no trailing slash). Used to build the
# "log today's homework" link inside reminder emails/SMS.
# On Railway this is your generated/custom domain.
SITE_URL=https://homework-tracker.up.railway.app

# ─── Reminders: Email (SendGrid) ─────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ─── Reminders: SMS (Twilio) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# ─── OneDrive daily backup (Microsoft Graph, refresh-token) ──────────────────
# Mint the refresh token once with: node scripts/setup-onedrive-backup.mjs
# The whole backup feature is gated on the first three vars being present.
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REFRESH_TOKEN=
# Target folder in the OneDrive root. Forward or back slashes both nest folders.
ONEDRIVE_BACKUP_FOLDER=HomeworkTrackerBackups
# Shared secret guarding POST /api/internal/run-backup (any long random string).
BACKUP_CRON_SECRET=
